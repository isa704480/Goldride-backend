# Goldride backend — environment variables namunasi
# Bu faylni `.env` deb nusxalab, qiymatlarni to'ldiring. `.env` HECH QACHON commit qilinmaydi.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# Database
USE_POSTGRES=False
DB_NAME=taksi_db
DB_USER=taksi_user
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis
USE_REDIS=False
REDIS_URL=redis://localhost:6379/0
CACHE_REDIS_URL=redis://localhost:6379/1

# OTP
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=4

# Pricing (UZS)
BASE_FARE=5000
PER_KM_RATE=2000
SHARED_DISCOUNT=0.30
COMMISSION_RATE=0.05

# Telegram — OTP/admin xabarnomalari uchun bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Telegram — reklama saytidagi "Fikringiz" formasi uchun ALOHIDA bot
# Bir nechta qabul qiluvchi: chat_id'larni vergul bilan ajrating
FEEDBACK_BOT_TOKEN=
FEEDBACK_CHAT_IDS=

# Email (Gmail/SMTP)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
